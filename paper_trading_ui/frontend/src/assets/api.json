{
  "schema_version": 1,
  "api_basics": [
    {
      "item": "Style",
      "details": "RESTful JSON API \u2014 standard HTTP verbs (GET, POST), JSON request/response bodies, HTTP status codes for errors."
    },
    {
      "item": "Backend Framework",
      "details": "FastAPI app in paper_trading_ui/backend/main.py."
    },
    {
      "item": "Base Path",
      "details": "Most application endpoints are under /api/ (plus /health for service checks)."
    },
    {
      "item": "Content Type",
      "details": "JSON request/response payloads."
    },
    {
      "item": "CORS",
      "details": "Configured via CORS_ORIGINS (comma-separated), defaults to *."
    },
    {
      "item": "Error Shape",
      "details": "HTTP errors return a detail message (FastAPI HTTPException)."
    }
  ],
  "endpoints": [
    {
      "method": "GET",
      "path": "/api/accounts",
      "handler": "api_accounts",
      "module": "accounts",
      "group": "Accounts & Snapshots Endpoints",
      "description": "List account summaries including equity, benchmark, PnL deltas, latest snapshot timing, and live benchmark summary fields when available."
    },
    {
      "method": "GET",
      "path": "/api/accounts/compare",
      "handler": "api_accounts_compare",
      "module": "accounts",
      "group": "Accounts & Snapshots Endpoints",
      "description": "Return all accounts with live equity stats, live benchmark return/alpha summaries, and latest backtest metrics for side-by-side comparison."
    },
    {
      "method": "GET",
      "path": "/api/accounts/config/options",
      "handler": "api_account_config_options",
      "module": "accounts",
      "group": "Accounts & Snapshots Endpoints",
      "description": "Return ordered option values and defaults for the account configuration editor."
    },
    {
      "method": "GET",
      "path": "/api/accounts/{account_name}",
      "handler": "api_account_detail",
      "module": "accounts",
      "group": "Accounts & Snapshots Endpoints",
      "description": "Get one account detail including positions, latest backtest summary, recent snapshots, recent trades, and liveBenchmarkOverlay data."
    },
    {
      "method": "PATCH",
      "path": "/api/accounts/{account_name}/params",
      "handler": "api_update_account_params",
      "module": "accounts",
      "group": "Accounts & Snapshots Endpoints",
      "description": "Partially update mutable account config, options, goals, and rotation settings."
    },
    {
      "method": "POST",
      "path": "/api/actions/snapshot-all",
      "handler": "api_snapshot_all",
      "module": "actions",
      "group": "Accounts & Snapshots Endpoints",
      "description": "Create equity snapshots for all managed accounts."
    },
    {
      "method": "POST",
      "path": "/api/actions/snapshot/{account_name}",
      "handler": "api_snapshot",
      "module": "actions",
      "group": "Accounts & Snapshots Endpoints",
      "description": "Create an equity snapshot for one account."
    },
    {
      "method": "GET",
      "path": "/health",
      "handler": "health",
      "module": "health",
      "group": "Accounts & Snapshots Endpoints",
      "description": "Simple health check. Returns {\"status\":\"ok\"} when backend is up."
    },
    {
      "method": "GET",
      "path": "/api/accounts/{account_name}/analysis",
      "handler": "api_account_analysis",
      "module": "analysis",
      "group": "Analysis Endpoints",
      "description": "Return account analysis including account return, benchmark return, alpha, PnL splits, top winners/losers, and improvement notes."
    },
    {
      "method": "POST",
      "path": "/api/accounts/{account_name}/trades",
      "handler": "api_add_trade",
      "module": "trades",
      "group": "Trading & Signals Endpoints",
      "description": "Insert a manual trade for the virtual test account after ticker validation and account-rule checks."
    },
    {
      "method": "POST",
      "path": "/api/features/signals",
      "handler": "api_feature_signals",
      "module": "features",
      "group": "Trading & Signals Endpoints",
      "description": "Run the feature-driven signal helpers for a ticker and return provider-specific signal/context payloads."
    },
    {
      "method": "GET",
      "path": "/api/features/status",
      "handler": "api_feature_status",
      "module": "features",
      "group": "Trading & Signals Endpoints",
      "description": "Return health/status details for the UI alt-strategy feature providers."
    },
    {
      "method": "POST",
      "path": "/api/admin/accounts/create",
      "handler": "api_admin_create_account",
      "module": "admin",
      "group": "Admin Endpoints",
      "description": "Create a new account with core fields, risk policy, options settings, and rotation settings."
    },
    {
      "method": "POST",
      "path": "/api/admin/accounts/delete",
      "handler": "api_admin_delete_account",
      "module": "admin",
      "group": "Admin Endpoints",
      "description": "Delete an account and its dependent data after explicit confirmation."
    },
    {
      "method": "GET",
      "path": "/api/admin/exports/csv",
      "handler": "api_csv_exports",
      "module": "admin",
      "group": "Admin Endpoints",
      "description": "List available CSV exports generated by repository data operations."
    },
    {
      "method": "GET",
      "path": "/api/admin/exports/csv/preview",
      "handler": "api_csv_export_preview",
      "module": "admin",
      "group": "Admin Endpoints",
      "description": "Preview rows from a selected CSV export file with a configurable row limit."
    },
    {
      "method": "GET",
      "path": "/api/admin/operations/overview",
      "handler": "api_operations_overview",
      "module": "admin",
      "group": "Admin Endpoints",
      "description": "Return current runtime job health, recent artifacts, and backup visibility."
    },
    {
      "method": "GET",
      "path": "/api/admin/promotion/overview",
      "handler": "api_promotion_overview",
      "module": "admin",
      "group": "Admin Endpoints",
      "description": "Return promotion readiness plus persisted review history for one account."
    },
    {
      "method": "GET",
      "path": "/api/logs/files",
      "handler": "api_log_files",
      "module": "logs",
      "group": "Logs Endpoints",
      "description": "Return available .log files from the configured logs directory."
    },
    {
      "method": "GET",
      "path": "/api/logs/{file_name}",
      "handler": "api_log_file",
      "module": "logs",
      "group": "Logs Endpoints",
      "description": "Return recent lines from a log file with optional filtering."
    },
    {
      "method": "GET",
      "path": "/api/backtests/latest/{account_name}",
      "handler": "api_latest_backtest_for_account",
      "module": "backtests",
      "group": "Backtesting Endpoints",
      "description": "Get the latest persisted backtest run summary for one account."
    },
    {
      "method": "POST",
      "path": "/api/backtests/preflight",
      "handler": "api_backtest_preflight",
      "module": "backtests",
      "group": "Backtesting Endpoints",
      "description": "Preview warnings for a proposed backtest configuration without executing it."
    },
    {
      "method": "POST",
      "path": "/api/backtests/run",
      "handler": "api_run_backtest",
      "module": "backtests",
      "group": "Backtesting Endpoints",
      "description": "Run a single backtest window and return persisted result metrics including Sharpe, Sortino, Calmar, win rate, profit factor, and average trade return."
    },
    {
      "method": "GET",
      "path": "/api/backtests/runs",
      "handler": "api_backtest_runs",
      "module": "backtests",
      "group": "Backtesting Endpoints",
      "description": "List recent backtest runs across accounts."
    },
    {
      "method": "GET",
      "path": "/api/backtests/runs/{run_id}",
      "handler": "api_backtest_run_report",
      "module": "backtests",
      "group": "Backtesting Endpoints",
      "description": "Get the full backtest report payload for a single run id."
    },
    {
      "method": "POST",
      "path": "/api/backtests/walk-forward",
      "handler": "api_run_walk_forward",
      "module": "backtests",
      "group": "Backtesting Endpoints",
      "description": "Execute rolling walk-forward windows and return aggregate summary metrics."
    }
  ]
}
